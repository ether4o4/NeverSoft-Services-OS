# Maintainer: Simon Schubert <sschubert89@gmail.com>
# https://github.com/ether4o4/MorsVitaEst

pkgname=morsvitaest-bin
pkgver=2.6.2
pkgrel=1
pkgdesc='AI assistant powered by Ollama, Gemini, ChatGPT and more'
arch=('x86_64')
url='https://github.com/ether4o4/MorsVitaEst'
license=('Apache-2.0')
depends=('hicolor-icon-theme')
provides=('morsvitaest')
conflicts=('morsvitaest')
options=('!strip')

source=("MorsVitaEst-${pkgver}-linux-x86_64.tar.gz::https://github.com/ether4o4/MorsVitaEst/releases/download/v${pkgver}/MorsVitaEst-${pkgver}-linux-x86_64.tar.gz")
sha256sums=('27b772999c7f5ae960b990b784620a33dece1789f2f9e2b433388cb87f1dcf0d')

package() {
    # Install application files
    install -dm755 "${pkgdir}/opt/morsvitaest"
    cp -r "${srcdir}/MorsVitaEst/"* "${pkgdir}/opt/morsvitaest/"
    chmod -R go-w "${pkgdir}/opt/morsvitaest"

    # Install wrapper script
    install -Dm755 /dev/stdin "${pkgdir}/usr/bin/morsvitaest" << 'EOF'
#!/bin/sh
exec /opt/morsvitaest/bin/MorsVitaEst "$@"
EOF

    # Install desktop entry
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/morsvitaest.desktop" << EOF
[Desktop Entry]
Name=MorsVitaEst
Comment=AI assistant powered by Ollama, Gemini, ChatGPT and more
Exec=morsvitaest
Icon=morsvitaest
Type=Application
Categories=Utility;Network;
Keywords=AI;Chat;Ollama;Gemini;LLM;Assistant;
StartupWMClass=compose-window
Terminal=false
EOF

    # Install icon
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/icons/hicolor/scalable/apps/morsvitaest.svg" << 'EOF'
<svg viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg">
   <circle cx="35" cy="45" r="30" fill="#6200ee" />
   <circle cx="55" cy="45" r="30" fill="#8063C5" />
</svg>
EOF

    # Install license
    install -Dm644 "${srcdir}/MorsVitaEst/lib/MorsVitaEst.copyright" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null ||
    install -Dm644 "${srcdir}/MorsVitaEst/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null || true
}

# Publishing steps:
# 1. Create AUR account at https://aur.archlinux.org
# 2. git clone ssh://aur@aur.archlinux.org/morsvitaest-bin.git
# 3. Copy PKGBUILD and .SRCINFO into the cloned repo
# 4. git add PKGBUILD .SRCINFO
# 5. git commit -m "Initial upload: morsvitaest-bin 1.7.9"
# 6. git push

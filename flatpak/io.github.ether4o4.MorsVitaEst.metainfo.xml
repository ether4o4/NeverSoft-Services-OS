<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.ether4o4.MorsVitaEst</id>

  <name>MorsVitaEst</name>
  <summary>AI assistant powered by Ollama, Gemini, ChatGPT and more</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>Apache-2.0</project_license>

  <developer id="io.github.ether4o4">
    <name>Simon Schubert</name>
  </developer>

  <description>
    <p>
      MorsVitaEst is a versatile AI assistant that connects to multiple AI services including
      Ollama, Google Gemini, OpenAI ChatGPT, Anthropic Claude, Mistral, Groq,
      OpenRouter, and any OpenAI-compatible API.
    </p>
    <p>Features:</p>
    <ul>
      <li>Chat with multiple AI providers from a single app</li>
      <li>Run local AI models via Ollama</li>
      <li>Text-to-speech support</li>
      <li>Image attachments and analysis</li>
      <li>Customizable system prompts</li>
      <li>Multiple conversation management</li>
      <li>Available on Android, iOS, Desktop, and Web</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.ether4o4.MorsVitaEst.desktop</launchable>

  <url type="homepage">https://github.com/ether4o4/MorsVitaEst</url>
  <url type="bugtracker">https://github.com/ether4o4/MorsVitaEst/issues</url>
  <url type="vcs-browser">https://github.com/ether4o4/MorsVitaEst</url>

  <branding>
    <color type="primary" scheme_preference="light">#e8f5e9</color>
    <color type="primary" scheme_preference="dark">#1b5e20</color>
  </branding>

  <screenshots>
